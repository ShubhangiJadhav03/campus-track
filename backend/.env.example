# ── Database ──────────────────────────────────
DB_USERNAME=root
DB_PASSWORD=root

# ── JWT ───────────────────────────────────────
JWT_SECRET=collegeComplaintSystemSecretKey2024VeryLongSecretKeyForHS512Algorithm
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ── File Upload ───────────────────────────────
UPLOAD_DIR=./uploads

# ── Mail (set MAIL_ENABLED=true to send emails) ─
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@college.edu

# ── CORS ──────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
